spring:
  application:
    name: server

  datasource:
    url: jdbc:postgresql://localhost:5432/pixelart
    username: postgres
    password: # 여기에 비밀번호 입력
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    open-in-view: false
    properties:
      hibernate:
        format_sql: true

  flyway:
    enabled: true
    baseline-on-migrate: true

  # 파일 업로드 한도 — ErrorCode.FILE_TOO_LARGE 메시지(최대 10MB)와 일치시켜야 함.
  # 미설정 시 Spring 기본값(파일 1MB)이라 메시지와 불일치 → 명시 필수.
  servlet:
    multipart:
      max-file-size: ${MULTIPART_MAX_FILE_SIZE:10MB}        # 파일 1개 한도
      max-request-size: ${MULTIPART_MAX_REQUEST_SIZE:50MB}  # 요청 전체 한도(미리보기 다중 업로드 대비)

  # 메일 발송(SMTP) — 프로덕션은 Brevo SMTP 릴레이 자격증명을 환경변수로 주입
  mail:
    host: ${MAIL_HOST:smtp-relay.brevo.com}
    port: ${MAIL_PORT:587}
    username: ${MAIL_USERNAME:}   # Brevo Login 이메일
    password: ${MAIL_PASSWORD:}   # Brevo SMTP key
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

server:
  port: 8080

# JWT — secret은 환경변수로 주입(미설정 시 로컬 dev 기본값). 만료는 ms 단위.
jwt:
  secret: ${JWT_SECRET:local-dev-secret-key-must-be-at-least-32-characters}
  access-token-expiry: ${JWT_ACCESS_TOKEN_EXPIRY:3600000}      # 1시간 (ms)
  refresh-token-expiry: ${JWT_REFRESH_TOKEN_EXPIRY:1209600000} # 14일 (ms)

# 이메일 인증 메일 발송 제어
# enabled=false(로컬): 실제 발송 대신 인증 링크를 콘솔 로그로 출력
# enabled=true(프로덕션): spring.mail.* 로 실제 발송
mail:
  enabled: ${MAIL_ENABLED:false}
  from: ${MAIL_FROM:pixelart@pixelpilot.art}            # Brevo에 등록·인증한 발신자 주소(샌더와 일치해야 함)
  verification-base-url: ${MAIL_VERIFICATION_BASE_URL:http://localhost:5173}  # 인증 링크가 가리킬 프론트 도메인

# OAuth2 소셜 로그인 — 등록(client-id 등)은 아래 'oauth' 프로파일에만 존재(키 없는 환경 기동 실패 방지).
# 활성화: SPRING_PROFILES_ACTIVE 에 oauth 추가(예: prod,oauth) + GOOGLE_CLIENT_ID/SECRET 주입.
# SecurityConfig는 ClientRegistrationRepository 빈이 있을 때만 .oauth2Login()을 켬 → 프로파일 미활성 시 자동으로 꺼짐.
oauth2:
  redirect-base-url: ${OAUTH2_REDIRECT_BASE_URL:http://localhost:5173}  # 로그인 성공 후 콜백 프론트 도메인

# AbuseIPDB IP 평판 기반 차단(Check API) — 들어오는 요청의 클라이언트 IP를 조회해 악성 점수가 높으면 403.
# enabled=false(로컬 기본): 조회 안 하고 전부 통과. enabled=true(프로덕션): API 키 필요.
# 무료 티어 Check 1,000회/일 → Caffeine 캐시(cache-ttl) + 인증된 요청 스킵으로 쿼터 보호.
# 외부 API 장애·타임아웃 시 fail-open(요청 통과) — 평판 서버 다운이 서비스 다운으로 번지지 않게.
abuseipdb:
  enabled: ${ABUSEIPDB_ENABLED:false}
  api-key: ${ABUSEIPDB_API_KEY:}            # https://www.abuseipdb.com 가입 후 발급
  score-threshold: ${ABUSEIPDB_SCORE_THRESHOLD:75}   # abuseConfidenceScore(0~100) 이 값 이상이면 차단(보수적=오탐↓)
  cache-ttl-seconds: ${ABUSEIPDB_CACHE_TTL:3600}     # IP→점수 캐시 유지 시간(초). 같은 IP 재조회 방지
  timeout-ms: ${ABUSEIPDB_TIMEOUT_MS:2000}           # Check API 호출 타임아웃(ms). 초과 시 fail-open

---
# ── 'oauth' 프로파일: 소셜 로그인 활성화 시에만 로드 ──
spring:
  config:
    activate:
      on-profile: oauth
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: ${GOOGLE_CLIENT_ID}
            client-secret: ${GOOGLE_CLIENT_SECRET}
            scope: email, profile